<Window x:Class="InfTimestamper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InfTimestamper"
        xmlns:vm="clr-namespace:InfTimestamper.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        Title="INF-TIMESTAMPER"
        Width="640" MinWidth="540"
        Height="600" MinHeight="480">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="過去の記録を開く..." Command="{Binding OpenRecordCommand}" />
                <MenuItem Header="記録を保存する..." Command="{Binding SaveRecordCommand}" />
                <Separator />
                <MenuItem Header="設定..." Command="{Binding OpenSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="About(_A)">
                <MenuItem Header="バージョン情報" IsEnabled="False" />
                <MenuItem Header="最新バージョンチェック" IsEnabled="False" />
                <MenuItem Header="GitHub" IsEnabled="False" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding HintText}" />
        </StatusBar>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- コントロールエリア -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="{Binding PrimaryButtonText}"
                        Command="{Binding PrimaryCommand}"
                        Width="120" Height="32" Margin="0,0,8,0"
                        ToolTip="状態に応じて 開始 / 強制開始 / 記録停止 / 記録再開 に切り替わる" />
                <Button Content="リセット"
                        Command="{Binding ResetCommand}"
                        Width="80" Height="32" Margin="0,0,8,0"
                        ToolTip="記録終了状態のみリセット可能" />
                <Button Content="コピー"
                        Command="{Binding CopyCommand}"
                        Width="80" Height="32"
                        ToolTip="タイムスタンプをクリップボードへコピー" />
            </StackPanel>

            <!-- 状態表示エリア -->
            <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ゲーム:" FontWeight="Bold" />
                    <TextBlock Text="{Binding GameName}" Margin="4,0,16,0" />
                    <TextBlock Text="状態:" FontWeight="Bold" />
                    <TextBlock Text="{Binding StateLabel}" Margin="4,0,0,0" />
                </StackPanel>
            </Border>

            <!-- 記録表示エリア（ヘッダ） -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="配信開始時間:" FontWeight="Bold" />
                <TextBlock Text="{Binding StreamStartedAtText}" Margin="4,0,16,0">
                    <TextBlock.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="日時を編集..."
                                      Command="{Binding PlacementTarget.DataContext.EditStreamStartedAtCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
                <TextBlock Text="タイムスタンプ数:" FontWeight="Bold" />
                <TextBlock Text="{Binding TimestampCount}" Margin="4,0,0,0" />
            </StackPanel>

            <!-- タイムスタンプリスト -->
            <ListBox Grid.Row="3"
                     x:Name="TimestampList"
                     ItemsSource="{Binding Timestamps}"
                     SelectionMode="Extended"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="選択項目の日時を編集..."
                                  Command="{Binding PlacementTarget.DataContext.EditSelectedTimestampsCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayText}"
                                       VerticalAlignment="Center"
                                       FontFamily="Consolas, Cascadia Mono" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>
